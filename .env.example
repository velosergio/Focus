# Variables de entorno para Focus en Easypanel (producción)
# Copiar este archivo como referencia al configurar el servicio en Easypanel > Environment.

# Perfil de Spring (obligatorio en producción)
SPRING_PROFILES_ACTIVE=prod

# Primera vez: crear tablas automáticamente. Luego quitar o poner validate.
# SPRING_JPA_HIBERNATE_DDL_AUTO=update

# Base de datos MySQL
DATABASE_URL=jdbc:mysql://tu-servidor-mysql:3306/focus
DATABASE_USERNAME=usuario_mysql
DATABASE_PASSWORD=contraseña_mysql

# JWT (obligatorio en producción; clave mín. 256 bits / 32 caracteres)
FOCUS_JWT_SECRET=tu-clave-secreta-muy-larga-y-aleatoria-min-32-chars

# Opcional: duración del token en ms (por defecto 86400000 = 24 h)
# FOCUS_JWT_EXPIRATION_MS=86400000

# Opcional: CORS si el frontend se sirve desde otro dominio (separar por coma).
# Vacío o sin definir = mismo origen (frontend incluido en el mismo despliegue).
# CORS_ALLOWED_ORIGINS=https://mi-app.easypanel.host
